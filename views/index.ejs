<%- include('partials/header') -%>

<!-- Hero -->
<section class="relative min-h-[88vh] flex items-center overflow-hidden">
  <!-- Glow blobs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(34,211,238,0.07) 0%, transparent 70%);"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(139,92,246,0.06) 0%, transparent 70%);"></div>

  <div class="max-w-6xl mx-auto px-6 py-24 relative z-10 w-full">
    <div class="max-w-3xl mx-auto text-center">
      <span class="section-label">Express · EJS · Tailwind</span>
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-[1.1] tracking-tight mb-6">
        Build something
        <span class="text-cyan-400"> beautiful</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-400 leading-relaxed mb-10 max-w-xl mx-auto">
        A modern website starter built with Node.js, Express, and Tailwind CSS. Fast, clean, and ready to customize.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="/shop" class="btn-primary">View Shop</a>
        <a href="/about" class="btn-ghost">Learn More</a>
      </div>
    </div>

    <!-- Floating stats -->
    <div class="mt-20 grid grid-cols-3 gap-4 max-w-lg mx-auto">
      <div class="card p-5 text-center">
        <p class="text-2xl font-bold text-white">6+</p>
        <p class="text-xs text-slate-500 mt-1">Products</p>
      </div>
      <div class="card p-5 text-center">
        <p class="text-2xl font-bold text-white">100%</p>
        <p class="text-xs text-slate-500 mt-1">Responsive</p>
      </div>
      <div class="card p-5 text-center">
        <p class="text-2xl font-bold text-white">Fast</p>
        <p class="text-xs text-slate-500 mt-1">Performance</p>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-24 border-t border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="section-label">What we offer</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Built for developers</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="card p-8 group transition-all duration-300 hover:-translate-y-1">
        <div class="w-10 h-10 rounded-xl bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center mb-5 text-cyan-400 text-lg">⚡</div>
        <h3 class="text-lg font-semibold text-white mb-3">Fast & Reliable</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Built with modern technologies for optimal performance across all devices.</p>
      </div>
      <div class="card p-8 group transition-all duration-300 hover:-translate-y-1">
        <div class="w-10 h-10 rounded-xl bg-violet-400/10 border border-violet-400/20 flex items-center justify-center mb-5 text-violet-400 text-lg">🎨</div>
        <h3 class="text-lg font-semibold text-white mb-3">Beautiful Design</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Modern dark UI with smooth interactions that look great and feel natural.</p>
      </div>
      <div class="card p-8 group transition-all duration-300 hover:-translate-y-1">
        <div class="w-10 h-10 rounded-xl bg-emerald-400/10 border border-emerald-400/20 flex items-center justify-center mb-5 text-emerald-400 text-lg">📱</div>
        <h3 class="text-lg font-semibold text-white mb-3">Fully Responsive</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Adapts perfectly to every screen size from mobile to widescreen.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stack section -->
<section class="py-24 border-t border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="card p-10 md:p-14">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="section-label">Tech stack</span>
          <h2 class="text-3xl font-bold text-white mb-5">Modern tools, solid foundation</h2>
          <p class="text-slate-400 leading-relaxed mb-8">
            This project uses Express.js for the server, EJS for dynamic HTML rendering, and Tailwind CSS for styling — a clean and beginner-friendly stack.
          </p>
          <a href="/about" class="btn-ghost">About the team</a>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-5 text-center">
            <p class="text-xs text-slate-500 mb-1">Backend</p>
            <p class="text-sm font-semibold text-white">Express.js</p>
          </div>
          <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-5 text-center">
            <p class="text-xs text-slate-500 mb-1">Templating</p>
            <p class="text-sm font-semibold text-white">EJS</p>
          </div>
          <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-5 text-center">
            <p class="text-xs text-slate-500 mb-1">Styling</p>
            <p class="text-sm font-semibold text-white">Tailwind</p>
          </div>
          <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-5 text-center col-span-3">
            <p class="text-xs text-slate-500 mb-1">Runtime</p>
            <p class="text-sm font-semibold text-white">Node.js</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') -%>
