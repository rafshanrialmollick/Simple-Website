<%- include('partials/header') -%>

<!-- Hero -->
<section class="relative py-24 border-b border-slate-800/60 overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 pointer-events-none" style="background: radial-gradient(circle, rgba(139,92,246,0.06) 0%, transparent 70%);"></div>
  <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
    <span class="section-label">Who we are</span>
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
      Building the web,<br/>one line at a time.
    </h1>
    <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
      We're a small, focused team passionate about crafting web experiences that are fast, beautiful, and meaningful.
    </p>
  </div>
</section>

<!-- Mission -->
<section class="py-24 border-b border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="section-label">Our mission</span>
        <h2 class="text-3xl font-bold text-white mb-6">Great design is more than how it looks</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          We believe great web design is about creating experiences that are intuitive, accessible, and delightful for every user who visits.
        </p>
        <p class="text-slate-400 leading-relaxed mb-8">
          Our mission is to build websites that inspire and deliver real value — combining cutting-edge technology with thoughtful creative decisions.
        </p>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-5 h-5 rounded-full bg-cyan-400/20 border border-cyan-400/30 flex items-center justify-center text-cyan-400 text-xs flex-shrink-0">✓</div>
            <span class="text-slate-300 text-sm">Innovation-first approach to every project</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-5 h-5 rounded-full bg-cyan-400/20 border border-cyan-400/30 flex items-center justify-center text-cyan-400 text-xs flex-shrink-0">✓</div>
            <span class="text-slate-300 text-sm">Uncompromising focus on quality and detail</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-5 h-5 rounded-full bg-cyan-400/20 border border-cyan-400/30 flex items-center justify-center text-cyan-400 text-xs flex-shrink-0">✓</div>
            <span class="text-slate-300 text-sm">Transparent, collaborative process with clients</span>
          </div>
        </div>
      </div>
      <div class="card p-10 flex items-center justify-center h-72">
        <span class="text-7xl">🚀</span>
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="py-24 border-b border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <span class="section-label">Core values</span>
      <h2 class="text-3xl font-bold text-white">What drives us</h2>
    </div>
    <div class="grid md:grid-cols-4 gap-5">
      <div class="card p-7 hover:-translate-y-1 transition-transform duration-300">
        <div class="text-3xl mb-4">💡</div>
        <h3 class="font-semibold text-white mb-2">Innovation</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Embracing new ideas and technology to build cutting-edge solutions.</p>
      </div>
      <div class="card p-7 hover:-translate-y-1 transition-transform duration-300">
        <div class="text-3xl mb-4">🤝</div>
        <h3 class="font-semibold text-white mb-2">Collaboration</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Working closely with clients to understand and exceed their expectations.</p>
      </div>
      <div class="card p-7 hover:-translate-y-1 transition-transform duration-300">
        <div class="text-3xl mb-4">⚡</div>
        <h3 class="font-semibold text-white mb-2">Excellence</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Delivering high-quality results with care and professionalism.</p>
      </div>
      <div class="card p-7 hover:-translate-y-1 transition-transform duration-300">
        <div class="text-3xl mb-4">🌱</div>
        <h3 class="font-semibold text-white mb-2">Growth</h3>
        <p class="text-slate-500 text-sm leading-relaxed">Continuously learning to stay ahead in a fast-moving industry.</p>
      </div>
    </div>
  </div>
</section>

<!-- Team -->
<section class="py-24 border-b border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <span class="section-label">The team</span>
      <h2 class="text-3xl font-bold text-white">People behind the work</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="card p-8 text-center hover:-translate-y-1 transition-transform duration-300">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-blue-600/20 border border-cyan-400/20 mx-auto mb-5 flex items-center justify-center text-4xl">👨‍💻</div>
        <h3 class="font-semibold text-white mb-1">John Developer</h3>
        <p class="text-cyan-400 text-xs font-medium tracking-wide uppercase mb-3">Full Stack Developer</p>
        <p class="text-slate-500 text-sm leading-relaxed">Expert in building scalable web apps with modern technologies.</p>
      </div>
      <div class="card p-8 text-center hover:-translate-y-1 transition-transform duration-300">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-500/20 to-pink-600/20 border border-violet-400/20 mx-auto mb-5 flex items-center justify-center text-4xl">👩‍🎨</div>
        <h3 class="font-semibold text-white mb-1">Sarah Designer</h3>
        <p class="text-violet-400 text-xs font-medium tracking-wide uppercase mb-3">UI/UX Designer</p>
        <p class="text-slate-500 text-sm leading-relaxed">Creative designer passionate about user experience.</p>
      </div>
      <div class="card p-8 text-center hover:-translate-y-1 transition-transform duration-300">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-500/20 to-teal-600/20 border border-emerald-400/20 mx-auto mb-5 flex items-center justify-center text-4xl">👩‍💼</div>
        <h3 class="font-semibold text-white mb-1">Emily Manager</h3>
        <p class="text-emerald-400 text-xs font-medium tracking-wide uppercase mb-3">Project Manager</p>
        <p class="text-slate-500 text-sm leading-relaxed">Keeps every project on track and clients happy.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="py-24 border-b border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="card p-8 text-center">
        <p class="text-4xl font-bold text-white mb-1">50+</p>
        <p class="text-slate-500 text-sm">Projects Completed</p>
      </div>
      <div class="card p-8 text-center">
        <p class="text-4xl font-bold text-white mb-1">100%</p>
        <p class="text-slate-500 text-sm">Client Satisfaction</p>
      </div>
      <div class="card p-8 text-center">
        <p class="text-4xl font-bold text-white mb-1">5+</p>
        <p class="text-slate-500 text-sm">Years Experience</p>
      </div>
      <div class="card p-8 text-center">
        <p class="text-4xl font-bold text-white mb-1">24/7</p>
        <p class="text-slate-500 text-sm">Support Available</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="card p-14 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to work together?</h2>
      <p class="text-slate-400 mb-8 max-w-md mx-auto">
        Browse our shop or learn more about what we build.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="/shop" class="btn-primary">Visit Shop</a>
        <a href="/" class="btn-ghost">Back to Home</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') -%>
