<%- include('partials/header') -%>

<!-- Hero -->
<section class="py-20 border-b border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <span class="section-label">Our Collection</span>
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Shop</h1>
    <p class="text-slate-400 max-w-xl mx-auto">
      Curated tech products for your workspace and lifestyle.
    </p>
  </div>
</section>

<!-- Products -->
<section class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between mb-10">
      <p class="text-slate-500 text-sm">
        Showing <span class="text-white font-medium"><%= products.length %></span> products
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% products.forEach((product, index) => { %>
      <div class="card group overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1">

        <!-- Image -->
        <div class="relative h-52 overflow-hidden bg-slate-900/60">
          <% if (index === 0) { %>
            <div class="absolute top-3 left-3 z-10 bg-cyan-400 text-slate-900 text-xs font-bold px-2.5 py-1 rounded-md">Featured</div>
          <% } %>
          <% if (index === 1) { %>
            <div class="absolute top-3 right-3 z-10 bg-rose-500 text-white text-xs font-bold px-2.5 py-1 rounded-md">−15%</div>
          <% } %>
          <img
            src="<%= product.image %>"
            alt="<%= product.name %>"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <!-- Dark overlay on hover -->
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300"></div>
        </div>

        <!-- Body -->
        <div class="p-6 flex flex-col flex-1">
          <!-- Stars -->
          <div class="flex items-center gap-1.5 mb-3">
            <div class="flex text-amber-400 text-xs">★★★★★</div>
            <span class="text-slate-600 text-xs">(<%= product.reviewCount %>)</span>
          </div>

          <h3 class="font-semibold text-white text-base mb-2 leading-snug"><%= product.name %></h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-5 flex-1"><%= product.description %></p>

          <!-- Price row -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-bold text-white">$<%= product.price.toFixed(2) %></span>
              <% if (index === 1) { %>
                <span class="text-slate-600 text-sm line-through">$<%= (product.price * 1.176).toFixed(2) %></span>
              <% } %>
            </div>
            <span class="text-emerald-400 text-xs font-medium bg-emerald-400/10 px-2.5 py-1 rounded-md border border-emerald-400/20">In stock</span>
          </div>

          <button class="w-full py-2.5 bg-cyan-400 hover:bg-cyan-300 active:scale-95 text-slate-900 font-semibold text-sm rounded-lg transition-all duration-200">
            Add to Cart
          </button>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Trust badges -->
<section class="py-16 border-t border-slate-800/60">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="text-2xl mb-3">🚚</div>
        <p class="text-sm font-medium text-white mb-1">Free Shipping</p>
        <p class="text-xs text-slate-600">On orders over $50</p>
      </div>
      <div class="text-center">
        <div class="text-2xl mb-3">🔒</div>
        <p class="text-sm font-medium text-white mb-1">Secure Checkout</p>
        <p class="text-xs text-slate-600">SSL encrypted</p>
      </div>
      <div class="text-center">
        <div class="text-2xl mb-3">↩️</div>
        <p class="text-sm font-medium text-white mb-1">Easy Returns</p>
        <p class="text-xs text-slate-600">30-day money back</p>
      </div>
      <div class="text-center">
        <div class="text-2xl mb-3">💬</div>
        <p class="text-sm font-medium text-white mb-1">24/7 Support</p>
        <p class="text-xs text-slate-600">Always here to help</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') -%>
