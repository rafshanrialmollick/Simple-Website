<%- include('partials/header') -%>

<main class="pt-24 pb-16">
  <div class="max-w-3xl mx-auto px-6">
    <h1 class="text-4xl font-bold mb-6 text-center tracking-tight">
      Contact Us
    </h1>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-600/20 border border-green-500 text-green-400 px-4 py-3 rounded-lg mb-6">
        Your message has been sent successfully! We'll get back to you soon.
      </div>
    <% } %>

    <form method="post" action="/contact" class="space-y-6 card p-8">
      <div>
        <label for="name" class="block text-sm font-medium text-slate-300 mb-2"
          >Name</label
        >
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-400 transition-colors duration-200"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-300 mb-2"
          >Email</label
        >
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-400 transition-colors duration-200"
        />
      </div>
      <div>
        <label
          for="message"
          class="block text-sm font-medium text-slate-300 mb-2"
          >Message</label
        >
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-400 transition-colors duration-200"
        ></textarea>
      </div>
      <button type="submit" class="btn-primary">Send Message</button>
    </form>
  </div>
</main>
<%- include('partials/footer') -%>
